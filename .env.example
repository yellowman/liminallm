# LiminalLM Environment Configuration
# Copy this file to .env and fill in the required values

# =============================================================================
# REQUIRED - Database
# =============================================================================
POSTGRES_PASSWORD=your_secure_password_here

# =============================================================================
# REQUIRED - Redis Authentication
# =============================================================================
REDIS_PASSWORD=your_secure_redis_password_here

# =============================================================================
# REQUIRED - OpenAI API (for LLM and embeddings)
# =============================================================================
# The adapter API key is used for LLM inference
OPENAI_ADAPTER_API_KEY=sk-your-openai-api-key-here
# Optional: Custom OpenAI-compatible endpoint
# OPENAI_ADAPTER_BASE_URL=https://api.openai.com/v1

# =============================================================================
# OPTIONAL - Authentication
# =============================================================================
# JWT_SECRET will be auto-generated and persisted if not provided
# JWT_SECRET=your-64-char-secure-secret

# JWT configuration
JWT_ISSUER=liminallm
JWT_AUDIENCE=liminal-clients
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_MINUTES=1440

# Enable/disable MFA requirement
ENABLE_MFA=true

# =============================================================================
# OPTIONAL - Model Configuration
# =============================================================================
# Backend selects the model provider. Supported values:
#   openai, anthropic, azure, azure_openai, vertex, gemini, google, bedrock,
#   together, together.ai, lorax, adapter_server, sagemaker, aws_sagemaker,
#   zhipu, zhipu.ai, glm, local_lora, local_gpu_lora, stub
# openai/anthropic/zhipu(glm)/together/gemini use OpenAI-compatible endpoints
# and read the matching *_API_KEY below. "stub" returns canned responses (tests).
MODEL_BACKEND=openai
# MODEL_PATH sets the model id/name (e.g. gpt-4o-mini, claude-opus-4-5, glm-5).
# MODEL_PATH=gpt-4o-mini
# MODEL_PATH=/path/to/local/model  # Only for local_lora / local_gpu_lora
ADAPTER_SERVER_MODEL=gpt-4o
EMBEDDING_MODEL_ID=text-embedding-3-small

# Per-provider API keys (set the one matching MODEL_BACKEND)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# ZHIPU_API_KEY=...          # used for zhipu / zhipu.ai / glm
# TOGETHER_API_KEY=...
# GEMINI_API_KEY=...
# Note: OPENAI_ADAPTER_BASE_URL / OPENAI_ADAPTER_API_KEY (set above) override
# the OpenAI endpoint/credentials when using the openai backend.

# =============================================================================
# OPTIONAL - Voice Configuration
# =============================================================================
VOICE_TRANSCRIPTION_MODEL=whisper-1
VOICE_SYNTHESIS_MODEL=tts-1
VOICE_DEFAULT_VOICE=alloy

# =============================================================================
# OPTIONAL - Email Configuration (for password reset, verification)
# =============================================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_USE_TLS=true
# EMAIL_FROM_ADDRESS=noreply@yourdomain.com
# EMAIL_FROM_NAME=LiminalLM

# Public URL for email links
APP_BASE_URL=http://localhost:8000

# =============================================================================
# OPTIONAL - OAuth Providers
# =============================================================================
# Google OAuth
# OAUTH_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# OAUTH_GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth
# OAUTH_GITHUB_CLIENT_ID=your-github-client-id
# OAUTH_GITHUB_CLIENT_SECRET=your-github-client-secret

# Microsoft OAuth
# OAUTH_MICROSOFT_CLIENT_ID=your-microsoft-client-id
# OAUTH_MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# OAuth redirect URI (must match provider configuration)
# OAUTH_REDIRECT_URI=https://yourdomain.com/

# =============================================================================
# Rate Limits (admin-managed, NOT env vars)
# =============================================================================
# Rate limits are stored in system_settings and edited via the admin UI /
# PUT /v1/admin/settings (keys like chat_rate_limit_per_minute). They are NOT
# read from the environment, so setting CHAT_RATE_LIMIT_PER_MINUTE here has no
# effect. Use 0 to disable a given limit. See SYSTEM_SETTINGS_DEFAULTS in
# liminallm/config.py for the full list of tunable keys.

# =============================================================================
# OPTIONAL - Multi-worker settings propagation
# =============================================================================
# The app runs multiple Uvicorn workers, each with its own in-process runtime.
# When an admin changes model settings, each worker reloads its model services
# after noticing the change; this controls how often (seconds) it checks.
# SETTINGS_WATCH_INTERVAL_SECONDS=10

# =============================================================================
# OPTIONAL - Ports
# =============================================================================
HOST_PORT=8000
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
